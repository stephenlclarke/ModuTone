{
  "name": "modutone",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "build:frontend": "tsc -b && vite build",
    "build:sidecar": "cargo build --release -p modutone-worker && node scripts/copy-sidecar.js",
    "build:sidecar:dev": "cargo build -p modutone-worker && node scripts/copy-sidecar.js --debug",
    "prepare:models": "node scripts/prepare-models.js",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:with-models": "tauri build --config src-tauri/tauri.models.conf.json",
    "package:bundle": "npm run prepare:models && npm run build && node scripts/package-bundle.js",
    "package:installer": "npm run prepare:models && npm run build && node scripts/create-sfx-installer.js",
    "package:linux": "npm run prepare:models && npm run build:with-models",
    "package:macos": "npm run prepare:models && npm run build:with-models",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "zustand": "^5.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vitest": "^3.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.0.0",
    "@playwright/test": "^1.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "globals": "^16.0.0"
  }
}
